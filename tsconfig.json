{
  "compilerOptions": {
    "target": "ES2017",
    "module": "ES2015",
    "outDir": "./app/static/js/dist",
    "rootDir": "./app/static/js/src", 
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["DOM", "ES2017"],
    "declaration": false,
    "removeComments": true,
    "sourceMap": true
  },
  "include": [
    "app/static/js/src/**/*"
  ],
  "exclude": [
    "node_modules",
    "app/static/js/dist"
  ]
}